  "rel_exclude": [

    "--- NOTE: patterns match the rel_type value after --handle-vocab-uris transformation.",
    "--- Default (IGNORE mode) strips to local name after last # or /.",
    "--- For KEEP mode (full URIs), add full-URI patterns in a custom --label-map-file.",

    "--- === Universal RDF/OWL/RDFS meta-predicates ===",
    "--- Identity / alignment — not semantic edges in the domain graph",
    "sameAs",
    "differentFrom",
    "equivalentClass",
    "equivalentProperty",
    "disjointWith",
    "complementOf",

    "--- Ontology structure — schema, not data",
    "subClassOf",
    "subPropertyOf",
    "domain",
    "range",
    "onProperty",
    "allValuesFrom",
    "someValuesFrom",
    "hasValue",
    "inverseOf",

    "--- SKOS alignment / mapping relations",
    "exactMatch",
    "closeMatch",
    "broadMatch",
    "narrowMatch",
    "relatedMatch",
    "mappingRelation",
    "inScheme",
    "topConceptOf",
    "hasTopConcept",

    "--- PROV-O provenance (infrastructure, not domain knowledge)",
    "wasDerivedFrom",
    "wasGeneratedBy",
    "wasAttributedTo",
    "wasInformedBy",
    "used",
    "hadPrimarySource",

    "--- VoID dataset descriptions",
    "void.*",

    "--- RDF reification (seldom useful as graph edges)",
    "subject",
    "predicate",
    "object",

    "--- === DBpedia-specific ===",
    "--- Wikipedia infrastructure — large but low-value for domain queries",
    "wikiPageExternalLink",
    "wikiPageUsesTemplate",
    "wikiPageWikiLink",
    "wikiPageDisambiguates",
    "wikiPageRedirects",
    "isPrimaryTopicOf",
    "primaryTopic",
    "wikiPageInterLanguageLink",
    "--- DBpedia provenance / housekeeping",
    "wasDerivedFrom",
    "isPartOf",

    "--- === Wikidata RDF (local name after stripping prop/direct/ etc.) ===",
    "--- Wikidata ontology meta-properties",
    "P279",
    "P31",
    "--- Wikidata infrastructure predicates (wikibase: / schema: namespace local names)",
    "directClaim",
    "claim",
    "statementProperty",
    "statementValue",
    "qualifier",
    "qualifierValue",
    "reference",
    "referenceValue",
    "normalizedValue",
    "rank",
    "bestRank",
    "preferredRank",
    "normalRank",
    "deprecatedRank",
    "timeZone",

    "--- === Bio / life sciences (UniProt, OBO, Reactome, ChEMBL, Bio2RDF) ===",
    "--- Cross-reference hubs — extremely dense, low discrimination",
    "seeAlso",
    "isDefinedBy",
    "source",
    "crossReference",
    "database",
    "xref",
    "hasDbXref",
    "closeMatch",
    "--- OBO meta-predicates",
    "is_a",
    "part_of",
    "has_part",
    "develops_from",
    "--- UniProt housekeeping",
    "mnemonic",
    "oldMnemonic",
    "reviewed",
    "created",
    "modified",
    "version",

    "--- === News / media datasets (GDELT, EventKG, NYT, Guardian) ===",
    "--- Provenance and publishing metadata",
    "mentions",
    "isAbout",
    "publishedIn",
    "hasAnnotation",

    "--- === Freebase-specific ===",
    "type.object.type",
    "type.type.instance",
    "kg.object_profile.prominent_type",
    "common.notable_for.*",
    "common.topic.notable_for",
    "common.topic.notable_types",
    "common.topic.topic_equivalent_webpage",
    "common.topic.article",
